{
  "manifest_version": 3,
  "name": "Smart Bug Reporter",
  "version": "1.1",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "smart-bug-reporter@tima.local"
    }
  }
}